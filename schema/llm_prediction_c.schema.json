{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/hasanyoussef/architect-worldcup/schema/llm_prediction_c.schema.json",
  "title": "Architect WorldCup Prediction C, the reconciled call",
  "description": "Per-tie reconciled forecast produced in Phase 2 with no tools, reading Prediction A, Prediction B, and the frozen dossier. It records what it took from A and from B and issues the reconciled three-way and advance. A is never edited.",
  "type": "object",
  "additionalProperties": false,
  "required": ["prediction", "round", "as_of_date", "git_sha", "model_version", "a_ref", "b_ref", "dossier_ref", "ties"],
  "properties": {
    "prediction": {"const": "C", "description": "Identifies this as the reconciled call."},
    "round": {"type": "string", "enum": ["R32", "R16", "QF", "SF", "F"]},
    "as_of_date": {"type": "string", "format": "date"},
    "committed_at": {"type": ["string", "null"], "description": "Git commit time, before-kickoff leakage proof. Null until committed."},
    "git_sha": {"type": "string"},
    "model_version": {"type": "string"},
    "a_ref": {"type": "string", "description": "Path and content hash of Prediction A this call read."},
    "b_ref": {"type": "string", "description": "Path and content hash of Prediction B this call read."},
    "dossier_ref": {"type": "string", "description": "Path and content hash of the frozen dossier this call read."},
    "ties": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "match", "home_team", "away_team", "took_from_a", "took_from_b",
          "reconciled_p_home_win_90", "reconciled_p_draw_90", "reconciled_p_away_win_90",
          "reconciled_shootout_lean", "reconciled_p_advance_home", "rationale", "provenance"
        ],
        "properties": {
          "match": {"type": "integer"},
          "home_team": {"type": "string", "description": "Nominal home, the first-listed team in the official fixture, the same labelling used by A and B."},
          "away_team": {"type": "string"},
          "took_from_a": {"type": "string", "description": "What the reconciliation drew from the math call."},
          "took_from_b": {"type": "string", "description": "What the reconciliation drew from the LLM analyst call."},
          "reconciled_p_home_win_90": {"type": "number", "minimum": 0, "maximum": 1},
          "reconciled_p_draw_90": {"type": "number", "minimum": 0, "maximum": 1},
          "reconciled_p_away_win_90": {"type": "number", "minimum": 0, "maximum": 1},
          "reconciled_shootout_lean": {"type": "number", "minimum": 0, "maximum": 1},
          "reconciled_p_advance_home": {"type": "number", "minimum": 0, "maximum": 1, "description": "reconciled_p_home_win_90 + reconciled_p_draw_90 * reconciled_shootout_lean."},
          "rationale": {"type": "string"},
          "provenance": {
            "type": "object",
            "additionalProperties": false,
            "required": ["model", "effort", "temperature", "cutoff", "a_ref", "b_ref", "dossier_ref"],
            "properties": {
              "model": {"type": "string"},
              "effort": {"type": "string"},
              "temperature": {"type": "string"},
              "cutoff": {"type": "string", "format": "date"},
              "a_ref": {"type": "string"},
              "b_ref": {"type": "string"},
              "dossier_ref": {"type": "string"},
              "committed_at": {"type": ["string", "null"]}
            }
          }
        }
      }
    }
  }
}
